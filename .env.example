# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to ".env" and fill in your real values.
# .env is git-ignored — never commit your real credentials.
# ─────────────────────────────────────────────────────────────────────────────

# ── Optional: Telegram notifications ────────────────────────────────────────
# Step 1: Open Telegram → search @BotFather → send /newbot → copy the token:
TELEGRAM_TOKEN=123456789:ABC-your-token-here

# Step 2: Send your bot any message, then visit:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
# Find "chat":{"id": <THIS_NUMBER>} and paste it here:
TELEGRAM_CHAT_ID=987654321

# ── Optional: Turso (libsql cloud DB) ───────────────────────────────────────
# Leave both blank to use the default local SQLite database created by the app.
# Sign up at https://turso.tech → create a database → copy the URL and token:
#   turso db create jobs
#   turso db show jobs --url        → paste as TURSO_URL
#   turso db tokens create jobs     → paste as TURSO_AUTH_TOKEN
TURSO_URL=
TURSO_AUTH_TOKEN=

# ── Optional: Redis cache ────────────────────────────────────────────────────
# Speeds up dashboard/API responses. Safe to leave blank.
REDIS_URL=

# ── Optional: OpenRouter LLM Enrichment (V3) ────────────────────────────────
# Sign up at https://openrouter.ai → create an API key:
OPENROUTER_API_KEY=

# Optional: model used for job enrichment (default: openai/gpt-oss-120b)
# Other cheap options: google/gemma-3-4b-it, mistralai/mistral-7b-instruct
ENRICHMENT_MODEL=openai/gpt-oss-120b
DESCRIPTION_FORMAT_MODEL=openai/gpt-oss-20b:paid

# ── Optional: local / hosted Qdrant for evidence retrieval ──────────────────
# For local Docker-based Qdrant, use:
#   QDRANT_URL=http://127.0.0.1:6333
# Keep QDRANT_API_KEY empty for local dev unless you explicitly secure it.
EVIDENCE_RETRIEVAL_MODE=auto
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_EVIDENCE_COLLECTION=candidate_evidence_chunks

