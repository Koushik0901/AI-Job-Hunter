# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to ".env" and fill in your real values.
# .env is git-ignored — never commit your real credentials.
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram ─────────────────────────────────────────────────────────────────
# Step 1: Open Telegram → search @BotFather → send /newbot → copy the token:
TELEGRAM_TOKEN=123456789:ABC-your-token-here

# Step 2: Send your bot any message, then visit:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
# Find "chat":{"id": <THIS_NUMBER>} and paste it here:
TELEGRAM_CHAT_ID=987654321

# ── SQLite Cloud (V2) ─────────────────────────────────────────────────────────
# Sign up at https://sqlitecloud.io → create a project → create a database
# → copy the connection string from the dashboard:
SQLITECLOUD_URL=sqlitecloud://your-host.sqlite.cloud:8860/jobs.db?apikey=your-api-key-here
