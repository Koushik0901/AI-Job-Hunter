# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to ".env" and fill in your real values.
# .env is git-ignored — never commit your real credentials.
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram ─────────────────────────────────────────────────────────────────
# Step 1: Open Telegram → search @BotFather → send /newbot → copy the token:
TELEGRAM_TOKEN=123456789:ABC-your-token-here

# Step 2: Send your bot any message, then visit:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
# Find "chat":{"id": <THIS_NUMBER>} and paste it here:
TELEGRAM_CHAT_ID=987654321

# ── Turso (libsql cloud DB) ───────────────────────────────────────────────────
# Sign up at https://turso.tech → create a database → copy the URL and token:
#   turso db create jobs
#   turso db show jobs --url        → paste as TURSO_URL
#   turso db tokens create jobs     → paste as TURSO_AUTH_TOKEN
TURSO_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here

# ── OpenRouter LLM Enrichment (V3) ───────────────────────────────────────────
# Sign up at https://openrouter.ai → create an API key:
OPENROUTER_API_KEY=sk-or-your-api-key-here

# Optional: model used for job enrichment (default: google/gemma-3-12b-it)
# Other cheap options: google/gemma-3-4b-it, mistralai/mistral-7b-instruct
ENRICHMENT_MODEL=google/gemma-3-12b-it

