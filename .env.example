# Copy this file to `.env` and fill in the values you use locally.

# Telegram notifications for new jobs and overdue staging jobs.
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
JOB_HUNTER_TIMEZONE=UTC

# Database configuration.
# Leave TURSO_* empty to use the local SQLite file at DB_PATH.
DB_PATH=jobs.db
TURSO_URL=
TURSO_AUTH_TOKEN=
REDIS_URL=redis://127.0.0.1:6379/0
DASHBOARD_CACHE_TTL_SHORT=60
DASHBOARD_CACHE_TTL_LONG=3600

# OpenRouter models used by the scraping/enrichment pipeline.
OPENROUTER_API_KEY=
ENRICHMENT_MODEL=openai/gpt-oss-120b
DESCRIPTION_FORMAT_MODEL=openai/gpt-oss-20b:paid
